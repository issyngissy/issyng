---
import { readdirSync } from "node:fs";
import {
	BUSINESS_NAME,
	BUSINESS_URL,
	CONTACT_EMAIL,
	SITE_OWNER,
} from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";

const hudFocus = [
	"AI automations",
	"CRM workflows",
	"SME growth",
	"websites",
	"SEO",
	"finance",
];

const experiences: Array<{
	role: string;
	company: string;
	dates: string;
	summary: string;
	tags: string[];
}> = [
	{
		role: "Founder",
		company: BUSINESS_NAME,
		dates: "Mar 2026 - Present",
		summary:
			"I work with Perth SMEs on websites, SEO and paid ads to grow their online presence.",
		tags: ["Websites", "SEO", "Google Ads", "Meta Ads"],
	},
	{
		role: "Sales & AI Automations",
		company: "GoFlo Solutions",
		dates: "Aug 2025 - Feb 2026",
		summary:
			"I built and deployed AI automations for small businesses, connecting tools like Google Workspace, Microsoft Office and APIs while mapping better workflows with owners.",
		tags: ["AI", "APIs", "Workflow Design"],
	},
	{
		role: "Co-Founder",
		company: "SkinAI",
		dates: "Apr 2025 - Aug 2025",
		summary:
			"Led product development, strategy and validation for an AI skincare tool using facial analysis, user input and dermatologist-backed logic.",
		tags: ["Product", "Validation", "Strategy"],
	},
	{
		role: "Financial Analyst",
		company: "Dradgin",
		dates: "Jun 2024 - Mar 2025",
		summary:
			"Built investment models, valuation analysis and financial forecasts to support finance decisions.",
		tags: ["Finance", "Valuation", "Modelling"],
	},
];

const formatCarouselCaption = (image: string) => {
	const separatorToken = "%%CAPTIONSEPARATOR%%";

	return image
		.replace(/\.[^.]+$/, "")
		.replace(/["“”]+/g, "")
		.replace(/\s+-\s+/g, ` ${separatorToken} `)
		.replace(/[-_]+/g, " ")
		.replaceAll(separatorToken, "-")
		.replace(/\s+/g, " ")
		.trim();
};

const monthIndexes: Record<string, number> = {
	jan: 0,
	feb: 1,
	mar: 2,
	apr: 3,
	may: 4,
	jun: 5,
	jul: 6,
	aug: 7,
	sep: 8,
	oct: 9,
	nov: 10,
	dec: 11,
};

const getCarouselDateRank = (image: string) => {
	const match = image.match(
		/\b(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\s+(\d{2})\b/i,
	);
	if (!match) return Number.POSITIVE_INFINITY;

	const month = monthIndexes[match[1].toLowerCase()];
	const year = 2000 + Number(match[2]);

	return year * 12 + month;
};

const carouselImages = readdirSync(
	new URL("../../public/carousel", import.meta.url),
)
	.filter((image) => /\.(avif|jpe?g|png|webp)$/i.test(image))
	.sort((a, b) => {
		const dateDifference = getCarouselDateRank(a) - getCarouselDateRank(b);
		if (dateDifference !== 0) return dateDifference;

		return a.localeCompare(b, undefined, {
			numeric: true,
			sensitivity: "base",
		});
	})
	.map((image) => ({
		file: image,
		caption: formatCarouselCaption(image),
	}));

const basePath = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const carouselImagePath = (image: string) =>
	`${basePath}carousel/${encodeURI(image).replaceAll("#", "%23")}`;
---

<BaseLayout navbarActiveItemID="home">
  <div class="relative">
    <section id="about" class="mt-6" aria-labelledby="about-heading">
      <div
        class="bg-black/30 border border-gray-600 rounded-lg font-mono text-sm p-6"
        role="region"
      >
        <!-- Terminal header -->
        <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-600">
          <div class="flex gap-2" role="img">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
        </div>
        <!-- Content -->
        <div class="text-xs">
          <div class="space-y-2">
            <div class="flex items-center gap-4 mb-4">
              <p class="text-3xl">🌱</p>
              <div class="flex flex-col">
                <h1 class="text-primary text-xl">{SITE_OWNER}</h1>
                <p class="text-gray-400 text-xs">
                  Founder. Commerce student. AI automations.
                </p>
              </div>
            </div>

            <!-- Personal paragraph -->
            <div class="home-bio bg-gray-500/10 rounded-lg p-3 mb-4">
              <p class="text-gray-200 leading-relaxed">
                Passionate about entrepreneurship and technology. Specifically, on how we use technology to optimise + leverage business decisions and operations. The application of software to Perth's SME's is what I have been exploring for the past year, and I am interested to learn more.
              </p>
            </div>

            <div class="border-b border-gray-600 w-full mb-2"></div>

            <div class="flex flex-col gap-1 sm:flex-row">
              <span class="text-gray-400 sm:w-36 shrink-0">Location</span>
              <span class="text-white">Perth, Australia 🇦🇺</span>
            </div>

            <div class="flex flex-col gap-1 sm:flex-row">
              <span class="text-gray-400 sm:w-36 shrink-0">Work</span>
              <span class="text-white">
                Founder,
                <a
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-cyan-600 hover:underline focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900"
                  href={BUSINESS_URL}
                  aria-label={`Visit ${BUSINESS_NAME}`}
                  >{BUSINESS_NAME}</a
                >
              </span>
            </div>

            <div class="flex flex-col gap-1 sm:flex-row">
              <span class="text-gray-400 sm:w-36 shrink-0">Main skill</span>
              <span class="text-white"
              >AI automations</span
              >
            </div>

            <div class="flex flex-col gap-1 sm:flex-row">
              <span class="text-gray-400 sm:w-36 shrink-0">Contact</span>
              <span class="text-white">
                <a
                  class="text-cyan-600 hover:underline focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900"
                  href={`mailto:${CONTACT_EMAIL}`}
                  aria-label={`Send email to ${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a
                >
              </span>
            </div>

            <div class="flex">
              <div class="flex flex-col gap-1 sm:flex-row sm:items-center">
                <span class="text-gray-400 sm:w-36 shrink-0">Focus</span>
                <div class="flex flex-wrap gap-2" role="list" aria-label="Focus areas">
                  {
                    hudFocus.map((focus) => (
                      <span
                        class="text-gray-400 hover:text-cyan-600 transition-colors"
                        title={focus}
                      >
                        {focus}
                      </span>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <section id="experience" class="mt-2">
      <div
        class="bg-black/20 border border-gray-700 rounded font-mono text-sm text-gray-300 p-6"
        role="region"
        aria-label="Experience timeline"
      >
        <h2 class="mb-4 text-sm font-bold text-gray-500">🧭 key experiences</h2>
        <div class="space-y-2" role="list">
          {
            experiences.map((experience, index) => (
              <article
                class="group hover:bg-gray-800/50 p-2 rounded transition-colors"
                role="listitem"
              >
                <div class="flex items-start gap-3">
                  <span class="text-gray-400 w-6 shrink-0" aria-hidden="true">
                    {String(index + 1).padStart(2, "0")}.
                  </span>
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                      <h3 class="text-white font-semibold">
                        {experience.role}
                        <span class="text-gray-500"> @ </span>
                        <span class="text-cyan-300">{experience.company}</span>
                      </h3>
                      <span class="text-gray-500 text-xs">{experience.dates}</span>
                    </div>

                    <p class="mt-1 text-gray-300 leading-relaxed">
                      {experience.summary}
                    </p>

                    <div class="mt-1 flex flex-wrap gap-2" aria-label={`${experience.company} skills`}>
                      {experience.tags.map((tag) => (
                        <span class="text-gray-500 text-xs">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

  </div>

  <Fragment slot="full-width">
    <section id="timeline" class="photo-section" aria-labelledby="timeline-heading">
      <div class="photo-section__header">
        <h2 id="timeline-heading" class="photo-section__title">timeline</h2>
      </div>

      <div class="photo-rail" aria-label="Timeline carousel">
        <div class="photo-rail__track">
          <div class="photo-rail__group">
            {
              carouselImages.map(({ file, caption }) => (
                <figure class="photo-rail__item" tabindex="0">
                  <span class="photo-rail__image-frame">
                    <img
                      src={carouselImagePath(file)}
                      alt={caption}
                      loading="lazy"
                      decoding="async"
                      class="photo-rail__image"
                    />
                  </span>
                  <figcaption class="photo-rail__caption">
                    {caption}
                  </figcaption>
                </figure>
              ))
            }
          </div>

          <div class="photo-rail__group photo-rail__group--duplicate" aria-hidden="true">
            {
              carouselImages.map(({ file, caption }) => (
                <figure class="photo-rail__item" tabindex="-1">
                  <span class="photo-rail__image-frame">
                    <img
                      src={carouselImagePath(file)}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      class="photo-rail__image"
                    />
                  </span>
                  <figcaption class="photo-rail__caption">
                    {caption}
                  </figcaption>
                </figure>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </Fragment>
</BaseLayout>

<style>
  .photo-section {
    position: relative;
    z-index: 10;
    width: 100%;
    margin-top: 0.75rem;
    padding: 1rem 0 3rem;
    font-family: var(--font-Departure);
    background: linear-gradient(
      to bottom,
      rgb(0 0 0 / 0%),
      rgb(0 0 0 / 42%) 18%,
      rgb(0 0 0 / 36%) 100%
    );
  }

  .photo-section__header {
    width: min(100%, 55rem);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .photo-section__title {
    color: rgb(107 114 128);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .photo-rail {
    overflow-x: auto;
    overflow-y: visible;
    width: 100%;
    padding: 1.25rem 1rem 1.75rem;
    scroll-padding-inline: 1rem;
    scroll-snap-type: x proximity;
    scrollbar-color: rgb(34 211 238 / 35%) transparent;
    scrollbar-width: thin;
  }

  .photo-rail::-webkit-scrollbar {
    height: 0.5rem;
  }

  .photo-rail::-webkit-scrollbar-track {
    background: transparent;
  }

  .photo-rail::-webkit-scrollbar-thumb {
    background: rgb(34 211 238 / 28%);
    border-radius: 999px;
  }

  .photo-rail__track {
    display: flex;
    width: max-content;
    align-items: flex-start;
  }

  .photo-rail__group {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .photo-rail__group--duplicate {
    display: none;
  }

  .photo-rail__item {
    position: relative;
    z-index: 0;
    flex: 0 0 clamp(11rem, 18vw, 17rem);
    margin: 0;
    cursor: zoom-in;
    scroll-snap-align: center;
    transform-origin: center bottom;
    transition:
      transform 180ms ease,
      opacity 180ms ease,
      filter 180ms ease;
  }

  .photo-rail__item:hover,
  .photo-rail__item:focus {
    z-index: 10;
    outline: 0;
    transform: translateY(-0.55rem) scale(1.1);
    opacity: 1;
  }

  .photo-rail__item:focus-visible {
    outline: 2px solid rgb(34 211 238 / 70%);
    outline-offset: 0.35rem;
    border-radius: 0.5rem;
  }

  .photo-rail__image-frame {
    display: block;
    width: 100%;
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 18px 45px rgb(0 0 0 / 36%);
  }

  .photo-rail__image {
    display: block;
    width: 100%;
    height: auto;
    opacity: 0.82;
  }

  .photo-rail__item:hover .photo-rail__image,
  .photo-rail__item:focus .photo-rail__image {
    opacity: 1;
    filter: saturate(1.1);
  }

  .photo-rail__caption {
    margin-top: 0.65rem;
    min-height: 2.4rem;
    color: rgb(209 213 219);
    font-size: 0.75rem;
    line-height: 1.3;
  }

  @media (min-width: 1180px) {
    .photo-section {
      position: fixed;
      top: 1rem;
      bottom: 1rem;
      left: calc(50vw + clamp(21rem, 25vw, 23rem));
      width: clamp(12rem, 17vw, 20rem);
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
      margin: 0;
      padding: 0;
      background: none;
    }

    .photo-section__header {
      width: 100%;
      margin: 0;
      padding: 0 0.15rem;
    }

    .photo-rail {
      flex: 1;
      min-height: 0;
      height: 100%;
      overflow: hidden;
      padding: 0;
      scroll-snap-type: none;
      scrollbar-width: none;
      mask-image: linear-gradient(
        to bottom,
        transparent 0,
        black 6%,
        black 94%,
        transparent 100%
      );
    }

    .photo-rail::-webkit-scrollbar {
      display: none;
    }

    .photo-rail__track {
      display: flex;
      width: 100%;
      flex-direction: column;
      animation: photo-rail-scroll 72s linear infinite;
      will-change: transform;
    }

    .photo-rail:hover .photo-rail__track,
    .photo-rail:focus-within .photo-rail__track {
      animation-play-state: paused;
    }

    .photo-rail__group,
    .photo-rail__group--duplicate {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      align-items: stretch;
      padding-bottom: 0.9rem;
    }

    .photo-rail__item {
      flex: 0 0 auto;
      cursor: zoom-in;
      display: flex;
      flex-direction: column;
      transform-origin: center right;
    }

    .photo-rail__image-frame {
      width: fit-content;
      max-width: 100%;
      margin-inline: auto;
    }

    .photo-rail__image {
      width: auto;
      max-width: 100%;
      max-height: clamp(12rem, 34vh, 22rem);
    }

    .photo-rail__item:hover,
    .photo-rail__item:focus {
      transform: translateX(-0.4rem) scale(1.04);
    }

    .photo-rail__caption {
      min-height: 0;
      font-size: 0.68rem;
    }
  }

  @media (min-width: 1180px) and (max-width: 1920px) {
    #about {
      margin-top: 0;
    }

    #about > div,
    #experience > div {
      padding: 1.1rem;
    }

    #about > div > div:first-child {
      margin-bottom: 0.7rem;
      padding-bottom: 0.75rem;
    }

    #about .space-y-2 {
      row-gap: 0.32rem;
    }

    #about .home-bio {
      margin-bottom: 0.7rem;
      padding: 0.6rem;
    }

    #experience {
      margin-top: 0.55rem;
    }

    #experience h2 {
      margin-bottom: 0.75rem;
    }

    #experience [role="list"] {
      row-gap: 0.35rem;
    }

    #experience article {
      padding: 0.35rem;
    }

    .photo-section {
      top: 0.65rem;
      bottom: 0.65rem;
      left: calc(50vw + clamp(21.5rem, 22.5vw, 23.5rem));
      width: clamp(9.5rem, 13vw, 13.5rem);
      gap: 0.55rem;
    }

    .photo-section__title {
      font-size: 0.8rem;
    }

    .photo-rail__group,
    .photo-rail__group--duplicate {
      gap: 0.72rem;
      padding-bottom: 0.72rem;
    }

    .photo-rail__image {
      max-height: clamp(9rem, 25vh, 14.5rem);
    }

    .photo-rail__caption {
      margin-top: 0.45rem;
      font-size: 0.62rem;
      line-height: 1.22;
    }
  }

  @media (min-width: 1180px) and (max-width: 1920px) and (max-height: 1100px) {
    #about > div,
    #experience > div {
      padding: 0.95rem;
    }

    #about .home-bio {
      margin-bottom: 0.55rem;
      padding: 0.55rem;
    }

    #experience article {
      padding: 0.35rem;
    }

    .photo-section {
      left: calc(50vw + clamp(21rem, 22vw, 23rem));
      width: clamp(9rem, 12vw, 12.75rem);
    }

    .photo-rail__image {
      max-height: clamp(8rem, 22vh, 12.5rem);
    }
  }

  @media (max-width: 640px) {
    #about p,
    #about span,
    #about a,
    #experience p {
      overflow-wrap: anywhere;
    }

    .photo-rail {
      padding-inline: 1rem;
      scroll-padding-inline: 1rem;
    }

    .photo-rail__item {
      flex-basis: clamp(9rem, 62vw, 13rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-rail__track,
    .photo-rail__item {
      animation: none;
      transition: none;
    }

    .photo-rail__group--duplicate {
      display: none;
    }
  }

  @keyframes photo-rail-scroll {
    from {
      transform: translateY(0);
    }

    to {
      transform: translateY(-50%);
    }
  }
</style>
