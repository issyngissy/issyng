---
import { readdirSync } from "node:fs";
import {
	BUSINESS_NAME,
	BUSINESS_URL,
	CONTACT_EMAIL,
	SITE_OWNER,
} from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";

const techStack: Record<string, string> = {
	web: "Website creation",
	seo: "SEO",
	ads: "Google and Meta ads",
	video: "Videography",
	ai: "AI automations",
	crm: "CRM workflows",
	product: "Product validation",
	sales: "Outbound sales",
	finance: "Financial analysis",
};

const experiences: Array<{
	role: string;
	company: string;
	dates: string;
	summary: string;
	tags: string[];
}> = [
	{
		role: "Founder",
		company: BUSINESS_NAME,
		dates: "Mar 2026 - Present",
		summary: "I help Perth small businesses look sharper online and turn traffic into leads.",
		tags: ["Websites", "SEO", "Google Ads", "Meta Ads"],
	},
	{
		role: "Sales & AI Automations",
		company: "GoFlo Solutions",
		dates: "Aug 2025 - Feb 2026",
		summary: "I sold and built AI automations that cleaned up admin-heavy workflows.",
		tags: ["AI", "APIs", "Workflow Design"],
	},
	{
		role: "Co-Founder",
		company: "SkinAI",
		dates: "Apr 2025 - Aug 2025",
		summary: "I worked on an AI skincare product and learned how to test a market before overbuilding.",
		tags: ["Product", "Validation", "Strategy"],
	},
	{
		role: "Financial Analyst",
		company: "Dradgin",
		dates: "Jun 2024 - Mar 2025",
		summary: "I built commercial property investment models and got a practical base in finance.",
		tags: ["Finance", "Modelling", "Property"],
	},
];

const carouselImages = readdirSync(
	new URL("../../public/carousel", import.meta.url),
)
	.filter((image) => /\.(avif|jpe?g|png|webp)$/i.test(image))
	.sort((a, b) =>
		a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" }),
	)
	.map((image) => ({
		file: image,
		caption: image.replace(/\.[^.]+$/, "").replaceAll("-", " "),
	}));

const basePath = import.meta.env.BASE_URL.endsWith("/")
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;

const carouselImagePath = (image: string) =>
	`${basePath}carousel/${encodeURIComponent(image)}`;
---

<BaseLayout navbarActiveItemID="home">
  <div class="relative">
    <section id="about" class="mt-6" aria-labelledby="about-heading">
      <div
        class="bg-black/30 border border-gray-600 rounded-lg font-mono text-sm p-6"
        role="region"
      >
        <!-- Terminal header -->
        <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-600">
          <div class="flex gap-2" role="img">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
        </div>
        <!-- Content -->
        <div class="text-xs">
          <div class="space-y-2">
            <div class="flex items-center gap-4 mb-4">
              <p class="text-3xl">🌱</p>
              <div class="flex flex-col">
                <h1 class="text-primary text-xl">{SITE_OWNER}</h1>
                <p class="text-gray-400 text-xs">
                  Founder. Commerce student. Operator.
                </p>
              </div>
            </div>

            <!-- Personal paragraph -->
            <div class="bg-gray-500/10 rounded-lg p-3 mb-4">
              <p class="text-gray-200 leading-relaxed">
                I am a commerce student and founder of Render Marketing. My work has moved across SME marketing, AI automation, product validation and commercial property analysis.
              </p>
            </div>

            <div class="border-b border-gray-600 w-full mb-2"></div>

            <div class="flex">
              <span class="text-gray-400 w-36 shrink-0">Location</span>
              <span class="text-white">Perth, Australia 🇦🇺</span>
            </div>

            <div class="flex">
              <span class="text-gray-400 w-36 shrink-0">Work</span>
              <span class="text-white">
                Founder,
                <a
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-cyan-600 hover:underline focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900"
                  href={BUSINESS_URL}
                  aria-label={`Visit ${BUSINESS_NAME}`}
                  >{BUSINESS_NAME}</a
                >
              </span>
            </div>

            <div class="flex">
              <span class="text-gray-400 w-36 shrink-0">Interests</span>
              <span class="text-white"
              >SME growth, AI automation, product, finance</span
              >
            </div>

            <div class="flex">
              <span class="text-gray-400 w-36 shrink-0">Contact</span>
              <span class="text-white">
                <a
                  class="text-cyan-600 hover:underline focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900"
                  href={`mailto:${CONTACT_EMAIL}`}
                  aria-label={`Send email to ${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a
                >
              </span>
            </div>

            <div class="flex">
              <div class="flex items-center">
                <span class="text-gray-400 w-36 shrink-0">Focus</span>
                <div class="flex flex-wrap gap-2" role="list" aria-label="Focus areas">
                  {
                    Object.keys(techStack).map((lang) => (
                      <span
                        class="text-gray-400 hover:text-cyan-600 transition-colors"
                        title={techStack[lang]}
                      >
                        {lang}
                      </span>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <section id="experience" class="mt-2">
      <div
        class="bg-black/20 border border-gray-700 rounded font-mono text-sm text-gray-300 p-6"
        role="region"
        aria-label="Experience timeline"
      >
        <h2 class="mb-4 text-sm font-bold text-gray-500">🧭 key experiences</h2>
        <div class="space-y-2" role="list">
          {
            experiences.map((experience, index) => (
              <article
                class="group hover:bg-gray-800/50 p-2 rounded transition-colors"
                role="listitem"
              >
                <div class="flex items-start gap-3">
                  <span class="text-gray-400 w-6 shrink-0" aria-hidden="true">
                    {String(index + 1).padStart(2, "0")}.
                  </span>
                  <div class="min-w-0 flex-1">
                    <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                      <h3 class="text-white font-semibold">
                        {experience.role}
                        <span class="text-gray-500"> @ </span>
                        <span class="text-cyan-300">{experience.company}</span>
                      </h3>
                      <span class="text-gray-500 text-xs">{experience.dates}</span>
                    </div>

                    <p class="mt-1 text-gray-300 leading-relaxed">
                      {experience.summary}
                    </p>

                    <div class="mt-1 flex flex-wrap gap-2" aria-label={`${experience.company} skills`}>
                      {experience.tags.map((tag) => (
                        <span class="text-gray-500 text-xs">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="photos" class="mt-2 pb-4" aria-labelledby="photos-heading">
      <div
        class="bg-black/20 border border-gray-700 rounded font-mono text-sm text-gray-300 py-6"
        role="region"
        aria-label="Photo carousel"
      >
        <h2 id="photos-heading" class="px-6 text-sm font-bold text-gray-500">
          photos
        </h2>

        <div class="photo-carousel" aria-label="Photo carousel">
          <div class="photo-carousel__track">
            {
              carouselImages.map(({ file, caption }) => (
                <figure class="photo-carousel__item" tabindex="0">
                  <img
                    src={carouselImagePath(file)}
                    alt={caption}
                    loading="lazy"
                    decoding="async"
                    class="photo-carousel__image"
                  />
                  <figcaption class="photo-carousel__caption">
                    {caption}
                  </figcaption>
                </figure>
              ))
            }
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .photo-carousel {
    overflow-x: auto;
    overflow-y: visible;
    padding: 1.25rem 1.5rem 1.75rem;
    scroll-padding-inline: 1.5rem;
    scroll-snap-type: x proximity;
    scrollbar-color: rgb(34 211 238 / 35%) transparent;
    scrollbar-width: thin;
  }

  .photo-carousel::-webkit-scrollbar {
    height: 0.5rem;
  }

  .photo-carousel::-webkit-scrollbar-track {
    background: transparent;
  }

  .photo-carousel::-webkit-scrollbar-thumb {
    background: rgb(34 211 238 / 28%);
    border-radius: 999px;
  }

  .photo-carousel__track {
    display: flex;
    width: max-content;
    gap: 1rem;
    align-items: stretch;
  }

  .photo-carousel__item {
    position: relative;
    z-index: 0;
    flex: 0 0 clamp(10rem, 22vw, 15rem);
    margin: 0;
    cursor: zoom-in;
    scroll-snap-align: center;
    transform-origin: center bottom;
    transition:
      transform 180ms ease,
      opacity 180ms ease,
      filter 180ms ease;
  }

  .photo-carousel__item:hover,
  .photo-carousel__item:focus {
    z-index: 10;
    outline: 0;
    transform: translateY(-0.55rem) scale(1.1);
    opacity: 1;
  }

  .photo-carousel__item:focus-visible {
    outline: 2px solid rgb(34 211 238 / 70%);
    outline-offset: 0.35rem;
    border-radius: 0.5rem;
  }

  .photo-carousel__image {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: 0.5rem;
    object-fit: cover;
    opacity: 0.78;
    box-shadow: 0 18px 45px rgb(0 0 0 / 36%);
  }

  .photo-carousel__item:hover .photo-carousel__image,
  .photo-carousel__item:focus .photo-carousel__image {
    opacity: 1;
    filter: saturate(1.1);
  }

  .photo-carousel__caption {
    margin-top: 0.65rem;
    min-height: 2.4rem;
    color: rgb(209 213 219);
    font-size: 0.75rem;
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .photo-carousel {
      padding-inline: 1rem;
      scroll-padding-inline: 1rem;
    }

    .photo-carousel__item {
      flex-basis: clamp(9rem, 62vw, 13rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .photo-carousel__item {
      transition: none;
    }
  }
</style>
