---
import {
	BUSINESS_NAME,
	BUSINESS_URL,
	CONTACT_EMAIL,
	GITHUB_URL,
	SITE_BASE,
	SITE_OWNER,
	SITE_URL,
	withBase,
} from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";

const techStack: Record<string, string> = {
	web: "Website creation",
	seo: "SEO",
	ads: "Meta ads",
	video: "Videography",
	ai: "AI automations",
	crm: "CRM workflows",
	sales: "Outbound sales",
};

const projects: Array<{
	title: string;
	description: string;
	link: string;
	icon: string;
}> = [
	{
		title: BUSINESS_NAME,
		description: "Websites, SEO, content and paid ads for small businesses",
		icon: "◈",
		link: BUSINESS_URL,
	},
	{
		title: "Resume",
		description: "2026 resume PDF",
		link: withBase("/resume.pdf"),
		icon: "▤",
	},
	{
		title: "GitHub",
		description: "Portfolio source and project work",
		icon: "⌘",
		link: GITHUB_URL,
	},
];
---

<BaseLayout navbarActiveItemID="home">
  <main>
    <section id="about" class="mt-6" aria-labelledby="about-heading">
      <div
        class="bg-black/30 border border-gray-600 rounded-lg font-mono text-sm p-6"
        role="region"
      >
        <!-- Terminal header -->
        <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-600">
          <div class="flex gap-2" role="img">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <span class="text-gray-400 text-xs ml-2"
            >$ xh {new URL(SITE_URL).host}{SITE_BASE}</span
          >
        </div>
        <!-- Content -->
        <div class="text-xs">
          <div class="space-y-2">
            <div class="flex items-center gap-4 mb-4">
              <p class="text-3xl">🌱</p>
              <div class="flex flex-col">
                <h1 class="text-primary text-xl">{SITE_OWNER}</h1>
                <p class="text-gray-400 text-xs">
                  Founder. Commerce student. Operator.
                </p>
              </div>
            </div>

            <!-- Personal paragraph -->
            <div class="bg-gray-500/10 rounded-lg p-3 mb-4">
              <p class="text-gray-200 leading-relaxed">
                I am a commerce student and founder of Render Marketing, building websites, AI automations, CRM workflows and marketing systems for small businesses in Perth.
              </p>
            </div>

            <div class="border-b border-gray-600 w-full mb-2"></div>

            <div class="flex">
              <span class="text-gray-400 w-36 shrink-0">Location</span>
              <span class="text-white">Perth, Australia 🇦🇺</span>
            </div>

            <div class="flex">
              <span class="text-gray-400 w-36 shrink-0">Work</span>
              <span class="text-white">
                Founder,
                <a
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-cyan-600 hover:underline focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900"
                  href={BUSINESS_URL}
                  aria-label={`Visit ${BUSINESS_NAME}`}
                  >{BUSINESS_NAME}</a
                >
              </span>
            </div>

            <div class="flex">
              <span class="text-gray-400 w-36 shrink-0">Interests</span>
              <span class="text-white"
              >SME growth, AI automation, sales, finance</span
              >
            </div>

            <div class="flex">
              <span class="text-gray-400 w-36 shrink-0">Contact</span>
              <span class="text-white">
                <a
                  class="text-cyan-600 hover:underline focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900"
                  href={`mailto:${CONTACT_EMAIL}`}
                  aria-label={`Send email to ${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a
                >
              </span>
            </div>

            <div class="flex">
              <div class="flex items-center">
                <span class="text-gray-400 w-36 shrink-0">Focus</span>
                <div class="flex flex-wrap gap-2" role="list" aria-label="Focus areas">
                  {
                    Object.keys(techStack).map((lang) => (
                      <span
                        class="text-gray-400 hover:text-cyan-600 transition-colors"
                        title={techStack[lang]}
                      >
                        {lang}
                      </span>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-3 pt-2 border-t border-gray-700 text-gray-500 text-xs">
          <span class="text-gray-400">$</span> bat about.txt
        </div>
      </div>
    </section>

    <section id="projects" class="mt-2">
      <div
        class="bg-black/20 border border-gray-700 rounded font-mono text-sm text-gray-300 p-6"
        role="region"
        aria-label="Project showcase"
      >
        <h2 class="mb-4 text-sm font-bold text-gray-500">💻 featured links</h2>
        <div class="space-y-2" role="list">
          {
            projects.map((project, index) => (
              <div
                class="group hover:bg-gray-800/50 p-1 rounded transition-colors"
                role="listitem"
              >
                {project.link ? (
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900 rounded"
                    aria-label={`Visit ${project.title}: ${project.description}`}
                  >
                    <div class="flex items-start gap-2">
                      <span
                        class="text-gray-400 w-6 shrink-0"
                        aria-hidden="true"
                      >
                        {String(index + 1).padStart(2, "0")}.
                      </span>
                      <span
                        class="text-yellow-360 shrink-0"
                        role="img"
                        aria-label="Project icon"
                      >
                        {project.icon}
                      </span>
                      <div class="min-w-0 flex-1">
                        <span class="text-white group-hover:text-cyan-300 font-semibold">
                          {project.title}
                        </span>
                        <span class="text-gray-500 ml-2">
                          → {project.description}
                        </span>
                      </div>
                    </div>
                  </a>
                ) : (
                  <div
                    class="flex items-start gap-2 opacity-60"
                    aria-label={`${project.title}: ${project.description} (Coming soon)`}
                  >
                    <span class="text-gray-400 w-6 shrink-0" aria-hidden="true">
                      {String(index + 1).padStart(2, "0")}.
                    </span>
                    <span
                      class="text-yellow-360 shrink-0"
                      role="img"
                      aria-label="Project icon"
                    >
                      {project.icon}
                    </span>
                    <div class="min-w-0 flex-1">
                      <span class="text-white font-semibold">
                        {project.title}
                      </span>
                      <span class="text-gray-500 ml-2">
                        → {project.description}
                      </span>
                      <span class="text-gray-600 ml-2">[coming soon]</span>
                    </div>
                  </div>
                )}
              </div>
            ))
          }
        </div>
        <div class="mt-3 pt-2 border-t border-gray-700 text-gray-500 text-xs">
          <span class="text-gray-400">$</span> eza -la projects/ | total {
            projects.length
          }
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
