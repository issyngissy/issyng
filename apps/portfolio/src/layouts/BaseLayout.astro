---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
import Plasma from "../components/Plasma";
import { SITE_DESCRIPTION, SITE_TITLE } from "../config";

const {
	image,
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	navbarActiveItemID,
} = Astro.props;
---

<!doctype html>
<html
  lang="en"
  class="dark h-full text-gray-400 selection:bg-cyan-700 selection:text-white"
>
  <head >

    <BaseHead title={title} description={description} image={image} />
  </head>
  <body class="relative min-h-screen overflow-x-hidden font-Departure text-gray-400 dark selection:bg-cyan-700 selection:text-white">

  <!-- Background layer -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
    <Plasma
      color="#6fd136"
      speed={0.45}
      direction="pingpong"
      scale={1.15}
      opacity={0.65}
      mouseInteractive={false}
      client:only="react"
    />
    <div class="absolute inset-0 bg-black/25"></div>
  </div>

  <!-- Foreground content -->
  <div class="site-shell relative z-10 w-full md:px-4">
  <div
    class="
      site-panel
      mt-6 rounded-2xl
      bg-black/50
      backdrop-blur-xl
      backdrop-saturate-150
      border border-white/10
      shadow-2xl
    "
  >
    <Header navbarActiveItemID={navbarActiveItemID} />

    <main id="main" class="px-4 md:px-8 pb-12 pt-4">
      <slot />
    </main>
  </div>
</div>

<slot name="full-width" />

</body>
</html>

<style>
  .site-shell {
    width: min(100%, calc(100vw - 3rem));
    max-width: 55rem;
    margin-right: auto;
    margin-left: auto;
  }

  @media (min-width: 768px) {
    .site-shell {
      width: min(100%, calc(100vw - 2rem));
    }
  }

  @media (min-width: 1180px) {
    .site-shell {
      max-width: min(55rem, calc(100vw - 24rem));
      transform: translateX(clamp(-7rem, -6vw, -4rem));
    }
  }

  @media (min-width: 1180px) and (max-width: 1600px) {
    .site-shell {
      max-width: min(51rem, calc(100vw - 21rem));
      transform: translateX(clamp(-4.5rem, -4vw, -3rem));
    }

    .site-panel {
      margin-top: 1rem;
      border-radius: 1rem;
    }

    #main-header {
      margin-top: 1rem;
      margin-bottom: 1.25rem;
      padding-inline: 1.5rem;
    }

    #main {
      padding: 0.25rem 1.5rem 2rem;
    }
  }

  @media (min-width: 1180px) and (max-width: 1600px) and (max-height: 900px) {
    .site-shell {
      max-width: min(49rem, calc(100vw - 21rem));
    }

    .site-panel {
      margin-top: 0.75rem;
    }
  }
</style>
