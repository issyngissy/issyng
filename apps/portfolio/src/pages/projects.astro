	},
	{
		name: "intro-to-C",
		description:
			'Currently reading "C Programming in UNIX Environment by Judy Kay & Bob Kummerfeld"',
		html_url: "https://github.com/issyngissy/intro-to-C",
		homepage: "",
		language: "C",
		topics: [],
		stargazers_count: 0,
		forks_count: 0,
		fork: false,
		archived: false,
