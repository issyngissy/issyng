---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
	GITHUB_URL,
	SITE_HANDLE,
	SITE_OWNER,
	SITE_REPOSITORY,
} from "../config";

type GitHubRepo = {
	name: string;
	description: string | null;
	html_url: string;
	homepage: string | null;
	language: string | null;
	topics?: string[];
	stargazers_count: number;
	forks_count: number;
	fork: boolean;
	archived: boolean;
	pushed_at: string;
	updated_at: string;
};

const fallbackRepos: GitHubRepo[] = [
