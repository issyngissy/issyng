];

const languageColors: Record<string, string> = {
	TypeScript: "#3178c6",
	JavaScript: "#f1e05a",
	Python: "#3572A5",
	Java: "#b07219",
	C: "#555555",
	HTML: "#e34c26",
	"Jupyter Notebook": "#DA5B0B",
};

const projectSummaries: Record<string, string> = {
	[SITE_REPOSITORY]:
		"Source for this portfolio site, built with Astro and deployed on GitHub Pages.",
	"field-frame":
		"Prototype workspace for testing interface ideas and lightweight product flows.",
	"AWSwebApp-notesapp-":
		"First AWS web app build: a simple notes app used to learn deployment basics.",
	networkingeventagent:
		"Automation that tracks ecosystem events and emails useful networking opportunities.",
	viralclippermaker:
		"Video clipping workflow for turning longer media content into short-form clips.",
	"Marketing-AI-Agent":
		"Experiment with a marketing-focused AI agent and workflow automation patterns.",
	themastersipwebsite: "Early website build for The Master Sip.",
};

const repoApiUrl = `https://api.github.com/users/${SITE_HANDLE}/repos?sort=pushed&per_page=100&type=owner`;

async function getRepos() {
	try {
		const response = await fetch(repoApiUrl, {
			headers: {
				Accept: "application/vnd.github+json",
				"User-Agent": `${SITE_HANDLE}-portfolio`,
			},
		});

		if (!response.ok) throw new Error(`GitHub API returned ${response.status}`);

		const data = (await response.json()) as GitHubRepo[];

		return {
			repos: Array.isArray(data) && data.length > 0 ? data : fallbackRepos,
			usedFallback: false,
		};
	} catch {
		return { repos: fallbackRepos, usedFallback: true };
	}
}

const { repos, usedFallback } = await getRepos();

const projects = repos
	.filter((repo) => !repo.archived)
	.filter((repo) => !repo.fork || repo.name === SITE_REPOSITORY)
	.sort(
		(a, b) =>
			new Date(b.pushed_at || b.updated_at).getTime() -
			new Date(a.pushed_at || a.updated_at).getTime(),
	);

const primaryProjects = projects.filter((repo) =>
	[
		SITE_REPOSITORY,
		"field-frame",
		"networkingeventagent",
		"viralclippermaker",
		"Marketing-AI-Agent",
		"AWSwebApp-notesapp-",
		"themastersipwebsite",
	].includes(repo.name),
);

const learningProjects = projects.filter(
	(repo) => !primaryProjects.some((project) => project.name === repo.name),
);

const languages = Object.entries(
	projects.reduce<Record<string, number>>((counts, repo) => {
		if (!repo.language) return counts;

		counts[repo.language] = (counts[repo.language] ?? 0) + 1;
		return counts;
	}, {}),
).sort(([, a], [, b]) => b - a);

const formatRepoName = (name: string) =>
	name.replace(/[-_]+/g, " ").replace(/\s+/g, " ").trim();

const getRepoSummary = (repo: GitHubRepo) =>
	projectSummaries[repo.name] || repo.description || "Work in progress.";

const formatDate = (date: string) =>
	new Intl.DateTimeFormat("en-AU", {
		month: "short",
		year: "numeric",
	}).format(new Date(date));

const syncLabel = new Intl.DateTimeFormat("en-AU", {
	day: "2-digit",
	month: "short",
	year: "numeric",
}).format(new Date());
---

<BaseLayout
  navbarActiveItemID="projects"
  title={`${SITE_OWNER} | GitHub Projects`}
  description={`GitHub projects and code by ${SITE_OWNER}.`}
>
  <section id="projects" class="mt-6" aria-labelledby="projects-heading">
    <div
      class="bg-black/30 border border-gray-600 rounded-lg font-mono text-sm p-6"
      role="region"
    >
      <div class="flex items-center gap-2 mb-4 pb-3 border-b border-gray-600">
        <div class="flex gap-2" role="img" aria-label="Window controls">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>
        <span class="text-gray-400 text-xs ml-2">$ gh repo list {SITE_HANDLE}</span>
      </div>

      <div class="text-xs space-y-5">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="flex items-center gap-4">
            <p class="text-3xl">⌘</p>
            <div class="flex flex-col">
              <h1 id="projects-heading" class="text-primary text-xl">
                github projects
              </h1>
              <p class="text-gray-400 text-xs">
                Code, experiments and build logs.
              </p>
            </div>
          </div>

          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex w-fit items-center gap-2 rounded border border-gray-700 px-3 py-2 text-gray-200 transition-colors hover:border-cyan-500 hover:text-cyan-300 focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900"
          >
            open GitHub
            <span aria-hidden="true">↗</span>
          </a>
        </div>

        <div class="grid gap-2 sm:grid-cols-3">
          <div class="border border-gray-700 rounded p-3">
            <div class="text-gray-500">repos</div>
            <div class="text-white text-lg">{projects.length}</div>
          </div>
          <div class="border border-gray-700 rounded p-3">
            <div class="text-gray-500">languages</div>
            <div class="text-white text-lg">{languages.length}</div>
          </div>
          <div class="border border-gray-700 rounded p-3">
            <div class="text-gray-500">synced</div>
            <div class="text-white text-lg">{syncLabel}</div>
          </div>
        </div>

        <div class="border-b border-gray-600 w-full"></div>

        {
          languages.length > 0 ? (
            <div class="flex flex-wrap gap-2" aria-label="Languages used">
              {languages.map(([language, count]) => (
                <span class="inline-flex items-center gap-2 rounded border border-gray-700 px-2 py-1 text-gray-300">
                  <span
                    class="h-2 w-2 rounded-full"
                    style={`background-color: ${languageColors[language] ?? "#6fd136"}`}
                    aria-hidden="true"
                  />
                  {language}
                  <span class="text-gray-600">{count}</span>
                </span>
              ))}
            </div>
          ) : null
        }

        <div class="space-y-3">
          <h2 class="text-gray-500 text-xs font-semibold">main projects</h2>

          <div class="space-y-2" role="list" aria-label="Main GitHub projects">
            {
              primaryProjects.map((repo, index) => (
                <article
                  class="group border border-gray-700 rounded p-3 transition-colors hover:border-cyan-600/70 hover:bg-gray-800/30"
                  role="listitem"
                >
                  <a
                    href={repo.html_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900 rounded"
                  >
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                      <div class="min-w-0">
                        <div class="flex items-center gap-2">
                          <span class="text-gray-500">
                            {String(index + 1).padStart(2, "0")}.
                          </span>
                          <h3 class="truncate text-white font-semibold group-hover:text-cyan-300">
                            {formatRepoName(repo.name)}
                          </h3>
                          <span class="text-gray-600" aria-hidden="true">↗</span>
                        </div>
                        <p class="mt-1 text-gray-300 leading-relaxed">
                          {getRepoSummary(repo)}
                        </p>
                      </div>

                      <div class="flex shrink-0 flex-wrap gap-2 text-gray-500 sm:justify-end">
                        {repo.language ? (
                          <span class="inline-flex items-center gap-1">
                            <span
                              class="h-2 w-2 rounded-full"
                              style={`background-color: ${languageColors[repo.language] ?? "#6fd136"}`}
                              aria-hidden="true"
                            />
                            {repo.language}
                          </span>
                        ) : null}
                        <span>{formatDate(repo.pushed_at || repo.updated_at)}</span>
                      </div>
                    </div>

                    <div class="mt-2 flex flex-wrap gap-3 text-gray-600">
                      <span>{repo.stargazers_count} stars</span>
                      <span>{repo.forks_count} forks</span>
                      {repo.homepage ? <span>live site</span> : null}
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
        </div>

        {
          learningProjects.length > 0 ? (
            <div class="space-y-3">
              <h2 class="text-gray-500 text-xs font-semibold">practice + learning</h2>

              <div class="grid gap-2 sm:grid-cols-2" role="list" aria-label="Practice repositories">
                {learningProjects.map((repo) => (
                  <a
                    href={repo.html_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group rounded border border-gray-800 p-3 transition-colors hover:border-cyan-700 hover:bg-gray-800/20 focus:outline-none focus:ring-2 focus:ring-cyan-600 focus:ring-offset-2 focus:ring-offset-gray-900"
                    role="listitem"
                  >
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0">
                        <div class="truncate text-white group-hover:text-cyan-300">
                          {formatRepoName(repo.name)}
                        </div>
                        <p class="mt-1 line-clamp-2 text-gray-500">
                          {repo.description || "Practice repo."}
                        </p>
                      </div>
                      <span class="text-gray-600" aria-hidden="true">↗</span>
                    </div>

                    <div class="mt-2 flex flex-wrap gap-2 text-gray-600">
                      {repo.language ? <span>{repo.language}</span> : null}
                      <span>{formatDate(repo.pushed_at || repo.updated_at)}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          ) : null
        }

        <div class="pt-2 border-t border-gray-700 text-gray-500 text-xs">
          <span class="text-gray-400">$</span> source {
            usedFallback ? "local fallback" : "github api"
          } | visible {projects.length}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
